-nodes-langchain.chatTrigger","typeVersion":1.4,"position":[-1968,384],"id":"392363ae-ea9b-4237-891d-e704f4aa1f80","name":"chatInput","webhookId":"60a4e465-3466-4e7a-ba81-7ebb1d39048c"},{"parameters":{"description":"Mandar llamar Subworkflow -> BTZ_Search_Stations_AI_SAFE","workflowId":{"__rl":true,"value":"cClrDh1F-m8htJYVXksRE","mode":"list","cachedResultUrl":"/workflow/cClrDh1F-m8htJYVXksRE","cachedResultName":"BTZ_Search_Stations_AI_SAFE"},"workflowInputs":{"mappingMode":"defineBelow","value":{"name":"={{ $fromAI('name', ``, 'string') }}"},"matchingColumns":["name"],"schema":[{"id":"name","displayName":"name","required":false,"defaultMatch":false,"display":true,"canBeUsedToMatch":true,"type":"string","removed":false}],"attemptToConvertTypes":false,"convertFieldsToString":false}},"type":"@n8n/n8n-nodes-langchain.toolWorkflow","typeVersion":2.2,"position":[288,624],"id":"1cce78ab-6fa6-425d-849a-f27c9c0c7ef3","name":"Call 'BTZ_Search_Stations_AI_SAFE'"},{"parameters":{"jsCode":"// BTZ_Search_Stations (AI-SAFE)\n// Entrada esperada (From AI): name (string)\n// Salida requerida por n8n tool: { response: \"texto\" }\n\nconst term = String($input.first().json.name ?? '').trim().toUpperCase();\n\n// Si no llega término, devolvemos instrucción corta (no catálogo completo)\nif (!term) {\n  return [{ json: { response: \"Falta el parámetro 'name'. Ejemplo: name='MONTERREY'.\" } }];\n}\n\n// Aquí NO llamamos a Betterez desde Code Tool (porque Code Tool no hace HTTP).\n// Este Tool es solo “formateador”. Para buscar en Betterez, necesitamos el HTTP tool filtrado.\n// Por ahora: devuelve el término normalizado para que el agente lo use en el HTTP tool filtrado.\nreturn [{ json: { response: `OK. Usar name=${term} para buscar estaciones.` } }];"},"type":"@n8n/n8n-nodes-langchain.toolCode","typeVersion":1.3,"position":[176,0],"id":"c249343c-2ea3-4d54-8ee5-38e92e7f5aba","name":"Code Tool_BTZ_Search_Stations","disabled":true},{"parameters":{"description":"Mandar llamar Subworkflow 